---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Nawi' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Nawi - Sistema Médico Minimalista" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
